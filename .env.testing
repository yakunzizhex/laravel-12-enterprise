APP_NAME="Laravel 12 Enterprise"
APP_ENV=testing
APP_KEY=base64:testing+key/with+special/chars==
APP_DEBUG=true

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

MAIL_MAILER=log

MFA_ENABLED=true
SECURITY_REQUIRE_MFA=false

TELESCOPE_ENABLED=false

AUDIT_ENABLED=true
